<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Tourizme" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/tourizme_logo</item>

        <item name="windowSplashScreenBackground">@color/sky_blue</item>


        <item name="postSplashScreenTheme">@style/Theme.Tourizme</item>
    </style>
</resources>